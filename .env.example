# WasteFlow — Variables d'environnement
# Copier ce fichier vers .env.local et remplir les valeurs
# cp .env.example .env.local

# ─── Base de données ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/wasteflow"
DIRECT_URL="postgresql://user:password@host:5432/wasteflow"

# ─── Authentification ─────────────────────────────────────────────────────────
JWT_SECRET="une-chaine-aleatoire-de-32-caracteres-minimum"
NEXT_PUBLIC_COOKIE_PREFIX="wf"

# ─── URL ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Redis (rate limiting) ────────────────────────────────────────────────────
# Upstash Redis REST
UPSTASH_REDIS_REST_URL="https://<id>.upstash.io"
UPSTASH_REDIS_REST_TOKEN="<token>"

# ─── Emails ───────────────────────────────────────────────────────────────────
RESEND_API_KEY="re_<key>"
EMAIL_FROM="WasteFlow <noreply@fluxdechets.com>"

# ─── Paiements ────────────────────────────────────────────────────────────────
# Clé pour les webhooks de paiement
CRON_SECRET="<secret-pour-cron-et-webhooks>"
# Clé AES-256-GCM pour chiffrer les API keys en base
ENCRYPTION_KEY="<32-caracteres-hex>"

# ─── Apify (scraping / prospection) ────────────────────────────────────────────
APIFY_TOKEN="<apify-token>"

# ─── Cartographie ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY="<google-maps-api-key>"

# ─── Sentry (optionnel) ──────────────────────────────────────────────────────
# SENTRY_ORG="wasteflow"
# SENTRY_PROJECT="fluxdechets"
# SENTRY_AUTH_TOKEN="<token>"
