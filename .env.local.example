# ====================================================
# WasteFlow — variables d'environnement
# Copier vers .env.local et remplir les valeurs
# ====================================================

# ─── Base de données (Neon Postgres) — OBLIGATOIRE ───
# Créer un projet gratuit sur https://neon.tech
# DATABASE_URL = URL avec pooler (-pooler dans le hostname)
DATABASE_URL="postgresql://user:pass@host-pooler.neon.tech/wasteflow?pgbouncer=true&connection_limit=1&pool_timeout=15&sslmode=require"
# DIRECT_URL = URL directe (sans pooler) pour les migrations Prisma
DIRECT_URL="postgresql://user:pass@host.neon.tech/wasteflow?sslmode=require"

# ─── Auth JWT — OBLIGATOIRE ───
# Générer avec : openssl rand -base64 32
JWT_SECRET="your-secret-here-min-32-chars"
ENCRYPTION_KEY="your-encryption-key-base64-32-bytes"

# ─── Cron jobs ───
# Générer avec : openssl rand -base64 32
CRON_SECRET="your-cron-secret"

# ─── App URL ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_COOKIE_PREFIX="wf"

# ─── Moneroo (Mobile Money — Tmoney/Flooz/Moov Togo) — Recommandé ───
# Créer un compte sur https://moneroo.io
# Priorité sur Bictorys si configuré. Seul gateway supportant Moov Money.
MONEROO_API_KEY=""
MONEROO_SECRET_KEY=""
MONEROO_WEBHOOK_SECRET=""

# ─── Bictorys (Mobile Money — Tmoney/Flooz Togo) — Optionnel ───
# Créer un compte sur https://bictorys.com
# Utilisé en fallback si Moneroo n'est pas configuré (tmoney/flooz uniquement).
BICTORYS_API_KEY=""
BICTORYS_PRIVATE_KEY=""
BICTORYS_WEBHOOK_SECRET=""
BICTORYS_MERCHANT_SECRET_CODE=""

# ─── Resend (emails) — Optionnel ───
# Créer un compte sur https://resend.com → API Keys → Create API Key
# Domaine à vérifier : fluxdechets.com (ajouter les DNS Resend dans Cloudflare)
RESEND_API_KEY=""
EMAIL_FROM="WasteFlow <noreply@fluxdechets.com>"

# ─── Upstash Redis (rate-limiting) — Optionnel mais recommandé en prod ───
# Créer une base sur https://upstash.com → Redis → Create Database (region: EU-West)
# Sans ces clés : rate-limit en mémoire (ne pas utiliser en prod multi-instance)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Google Maps / Places API — Optionnel ───
# Créer une clé sur https://console.cloud.google.com → APIs & Services → Credentials
# Activer : "Places API" + "Maps JavaScript API"
# Restreindre la clé à fluxdechets.com (HTTP referrers)
GOOGLE_MAPS_API_KEY=""

# ─── Google Search Console — Optionnel (SEO) ───
# Vérifier le site sur https://search.google.com/search-console
# Méthode : "Balise HTML" → copier la valeur du content="..."
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# ─── Apify (scraping automatique) — Optionnel ───
# Créer un compte sur https://apify.com → Settings → Integrations → API token
# Utilisé pour : découvrir abonnés potentiels (Google Maps), veille DSP (Google Search)
# Seuls les admins peuvent déclencher des scrapes depuis /api/scraping
APIFY_TOKEN=""

# ─── Sentry (monitoring) — Optionnel ───
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
